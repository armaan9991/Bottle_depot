FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /app

COPY . ./

WORKDIR /app/BottleDepot

RUN dotnet publish -c Release -o out

FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app

COPY --from=build /app/BottleDepot/out .

ENV Jwt__Key=BottleDepotSuperSecretKey2024Calgary!XYZ
ENV Jwt__Issuer=BottleDepot
ENV Jwt__Audience=BottleDepotUsers

ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080

ENTRYPOINT ["dotnet", "BottleDepot.dll"]